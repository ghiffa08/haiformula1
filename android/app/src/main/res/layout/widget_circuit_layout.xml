<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_circuit_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_widget_background"
    android:padding="16dp">

    <!-- Top Left: Country and Locality -->
    <LinearLayout
        android:id="@+id/widget_circuit_location_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_circuit_country"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="COUNTRY"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textAllCaps="true"/>

        <TextView
            android:id="@+id/widget_circuit_locality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif"
            android:text="Locality"
            android:textColor="#AAAAAA"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Top Right: Flag -->
    <ImageView
        android:id="@+id/widget_circuit_flag"
        android:layout_width="32dp"
        android:layout_height="24dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:background="#222222"
        android:scaleType="centerCrop" />

    <!-- Center: Circuit Layout -->
    <ImageView
        android:id="@+id/widget_circuit_silhouette"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_above="@+id/widget_circuit_bottom_container"
        android:layout_below="@+id/widget_circuit_location_container"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_circuit_placeholder" />

    <!-- Bottom Container -->
    <RelativeLayout
        android:id="@+id/widget_circuit_bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">

        <!-- Left: Session Info -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/widget_circuit_indicator"
                    android:layout_width="4dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="6dp"
                    android:background="#00FF00" />

                <TextView
                    android:id="@+id/widget_circuit_session"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-bold"
                    android:text="Session"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_circuit_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                android:text="Date"
                android:textColor="#888888"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Right: Time -->
        <TextView
            android:id="@+id/widget_circuit_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif"
            android:text="00:00"
            android:textColor="#AAAAAA"
            android:textSize="16sp" />
    </RelativeLayout>
</RelativeLayout>
